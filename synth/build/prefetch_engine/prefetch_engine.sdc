# prefetch_engine.sdc — generated by run_synth.sh; units follow the liberty (ps)
create_clock -name clk -period 2000 [get_ports clk]
set_input_delay  400 -clock clk \
  [remove_from_collection [all_inputs] [get_ports clk]]
set_output_delay 400 -clock clk [all_outputs]
set_false_path -from [get_ports rst_n]
